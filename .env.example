# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# OpenRouter (for chat LLM)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# API
API_PORT=8080
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# RAG tuning
RAG_TOP_K=5

# Rate limiting
CHAT_RATE_LIMIT=10          # Max chat requests per window per IP
SEARCH_RATE_LIMIT=20        # Max search requests per window per IP
RATE_LIMIT_WINDOW_MS=60000  # Rate limit window in ms (default: 1 minute)

# Cost controls
MAX_TOKENS=1024             # Max tokens per LLM response
